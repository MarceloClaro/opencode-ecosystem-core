{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opencode-ecosystem-core/schemas/scientific_claim.schema.json",
  "title": "ScientificClaim v2.0",
  "type": "object",
  "required": [
    "claim_id",
    "hypothesis",
    "null_hypothesis",
    "experimental_design",
    "metrics",
    "statistical_tests",
    "limitations",
    "reproducibility_score",
    "calibrated_confidence",
    "final_verdict",
    "domain",
    "falsifiable",
    "bayesian_prior",
    "sesoi"
  ],
  "properties": {
    "claim_id": { "type": "string", "minLength": 3 },
    "hypothesis": { "type": "string", "minLength": 10 },
    "null_hypothesis": { "type": "string", "minLength": 5 },
    "effect_direction": {
      "type": "string",
      "enum": ["positive", "negative", "two_sided"]
    },
    "domain": { "type": "string" },
    "bayesian_prior": { "type": "number", "minimum": 0, "maximum": 1 },
    "sesoi": { "type": "number", "minimum": 0 },
    "falsifiable": { "type": "boolean" },
    "version": { "type": "string" },
    "experimental_design": {
      "type": "object",
      "required": ["type", "sample_strategy", "stop_criteria", "power_level", "alpha"],
      "properties": {
        "type": { "type": "string" },
        "sample_strategy": { "type": "string" },
        "stop_criteria": { "type": "string" },
        "power_level": { "type": "number", "minimum": 0, "maximum": 1 },
        "alpha": { "type": "number", "minimum": 0, "maximum": 1 },
        "n_arms": { "type": "integer", "minimum": 1 },
        "n_per_group": { "type": "integer", "minimum": 0 },
        "total_sample_size": { "type": "integer", "minimum": 0 },
        "blinding": { "type": "string" },
        "pre_registered": { "type": "boolean" },
        "confounders_controlled": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "dataset_refs": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "metrics": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "statistical_tests": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "effect_size": { "type": ["number", "null"] },
    "p_value": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "p_value_corrected": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "confidence_interval": {
      "type": ["array", "null"],
      "items": { "type": "number" },
      "minItems": 2,
      "maxItems": 2
    },
    "bayes_factor": {
      "type": ["object", "null"],
      "properties": {
        "BF10": { "type": "number", "minimum": 0 },
        "BF01": { "type": "number", "minimum": 0 }
      }
    },
    "bayes_factor_interpretation": { "type": "string" },
    "evidence_score": { "type": "integer", "minimum": 0, "maximum": 10 },
    "evidence_strength": {
      "type": "string",
      "enum": ["strong", "moderate", "weak", "none"]
    },
    "statistical_power": { "type": "number", "minimum": 0, "maximum": 1 },
    "sample_size": { "type": "integer", "minimum": 0 },
    "effect_size_classification": {
      "type": "object",
      "properties": {
        "classification": { "type": "string" },
        "magnitude": { "type": "string" }
      }
    },
    "limitations": {
      "type": "array",
      "items": { "type": "string" }
    },
    "reproducibility_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "calibrated_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "brier_score": { "type": ["number", "null"] },
    "should_abstain": { "type": "boolean" },
    "abstention_reason": { "type": ["string", "null"] },
    "adversarial_findings": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "adversarial_overridden": { "type": "boolean" },
    "final_verdict": {
      "type": "string",
      "enum": ["supported", "inconclusive", "refuted"]
    }
  }
}
