{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opencode-ecosystem-core/schemas/scientific_claim.schema.json",
  "title": "ScientificClaim",
  "type": "object",
  "required": [
    "claim_id",
    "hypothesis",
    "null_hypothesis",
    "experimental_design",
    "metrics",
    "statistical_tests",
    "limitations",
    "reproducibility_score",
    "calibrated_confidence",
    "final_verdict"
  ],
  "properties": {
    "claim_id": { "type": "string", "minLength": 3 },
    "hypothesis": { "type": "string", "minLength": 10 },
    "null_hypothesis": { "type": "string", "minLength": 5 },
    "experimental_design": {
      "type": "object",
      "required": ["type", "sample_strategy", "stop_criteria"],
      "properties": {
        "type": { "type": "string" },
        "sample_strategy": { "type": "string" },
        "stop_criteria": { "type": "string" }
      },
      "additionalProperties": true
    },
    "dataset_refs": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "metrics": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "statistical_tests": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "effect_size": { "type": ["number", "null"] },
    "confidence_interval": {
      "type": ["array", "null"],
      "items": { "type": "number" },
      "minItems": 2,
      "maxItems": 2
    },
    "p_value": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "bayes_factor": { "type": ["number", "null"], "minimum": 0 },
    "limitations": {
      "type": "array",
      "items": { "type": "string" }
    },
    "reproducibility_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "calibrated_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "adversarial_findings": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "final_verdict": {
      "type": "string",
      "enum": ["supported", "inconclusive", "refuted"]
    }
  },
  "additionalProperties": false
}
