# ============================================================================
# .env.example — modelo de variáveis de ambiente do OpenCode Ecosystem Core
# ============================================================================
# COPIE este arquivo para `.env` (que é ignorado pelo git) e preencha os
# valores. NUNCA cole uma chave real neste arquivo versionado, nem em
# nenhum arquivo rastreado pelo git.
#
#     cp .env.example .env       # depois edite .env com as suas chaves
#
# Como o `.env` é carregado: exporte as variáveis na sua sessão (ou use um
# carregador como `direnv`/`dotenv`). O ecossistema lê estas variáveis do
# ambiente — ver research/llm_client.py.
# ----------------------------------------------------------------------------

# --- Provedor LLM local (via Ollama) — RECOMENDADO: custo zero e privado ---
# Se o Ollama estiver rodando, o pipeline de pesquisa (fichamento/resenha)
# o usa por padrão (provider="auto" prioriza o local antes da nuvem).
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# --- Provedor LLM de nuvem (OpenAI e compatíveis) — fallback opcional ------
# Preencha OPENAI_API_KEY no seu .env (NÃO aqui) para habilitar o fallback
# de nuvem. Custa tokens reais — o local (Ollama) continua sendo preferido.
# OPENAI_API_BASE permite apontar para endpoints OpenAI-compatíveis
# (ex.: OpenRouter, Together, um gateway próprio); padrão = OpenAI oficial.
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# --- OpenCode CLI ----------------------------------------------------------
# O opencode.json referencia estas variáveis via {env:...}. Para usar um
# provedor OpenAI-compatível no OpenCode CLI, defina a chave correspondente.
OPENCODE_API_KEY=
OPENCODE_ZEN_API_KEY=
