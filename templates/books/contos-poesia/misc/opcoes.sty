% =============================================================================
% Estilo tipográfico para coletânea de contos e poesia
% (cada capítulo é um texto autocontido — sem dependência narrativa entre eles)
% =============================================================================

% Valores padrão — evita "Undefined control sequence" quando este arquivo é
% carregado por um main.tex que não define estes metadados antes do \usepackage
% (ex.: projetos gerados automaticamente pelo pdf2latex).
\providecommand{\autornome}{Autor Desconhecido}
\providecommand{\titulolivro}{Título Não Definido}

% Carrega babel apenas se ainda não foi carregado por outro main.tex
% (evita "Option clash for package babel" quando este .sty é reaproveitado
% por um projeto que já define seu próprio idioma, ex.: pdf2latex).
\makeatletter
\@ifpackageloaded{babel}{}{\usepackage[brazilian]{babel}}
\makeatother
\addto\captionsbrazilian{\renewcommand{\contentsname}{Sumário}}

\usepackage{lettrine}
\usepackage{graphicx}
\usepackage{xcolor}
\usepackage{ebgaramond}
\linespread{1.1}

% Ambiente simples para poemas (evita depender do pacote externo "verse",
% nem sempre presente em instalações mínimas de TeX Live).
% Uso: \begin{poema} verso 1 \\ verso 2 \\[6pt] verso 3 \end{poema}
\newenvironment{poema}
  {\begin{quote}\itshape\raggedright\ignorespaces}
  {\par\end{quote}}

\setlength{\parskip}{0pt}
\setlength{\parindent}{1.2em}
\frenchspacing
\widowpenalty=10000
\clubpenalty=10000

% Formato de bolso (trade paperback 5.5in x 8.5in) — carrega o pacote sem
% opções (idempotente mesmo se já carregado por outro main.tex, ex.:
% pdf2latex) e aplica as dimensões via comando \geometry, que sempre
% sobrescreve sem gerar "Option clash".
\usepackage{geometry}
\geometry{
    paperwidth=5.5in,
    paperheight=8.5in,
    top=0.8in,
    bottom=0.8in,
    outer=0.7in,
    inner=0.9in
}

\usepackage{titlesec}
\titleformat{\part}[display]
  {\centering\normalfont\huge\scshape}
  {\partname~\thepart}{20pt}{\Huge}
\titleformat{\chapter}[display]
  {\normalfont\scshape\Large\centering}
  {}
  {0pt}
  {\vspace{4pt}}
\titlespacing*{\chapter}{0pt}{30pt}{20pt}

\usepackage{fancyhdr}
\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0pt}
\fancyfoot[C]{\thepage}
\fancyhead[LE]{\itshape\autornome}
\fancyhead[RO]{\itshape\titulolivro}

% Letra capitular de abertura de conto — uso: \letracapitular{H}{avia}
\newcommand{\letracapitular}[2]{\lettrine[lines=3,loversize=0.15,lraise=0.05]{#1}{#2}}
